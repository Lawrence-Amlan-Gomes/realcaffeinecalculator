---
const footerLinks = [
  { href: '/about', label: 'About' },
  { href: '/privacy-policy', label: 'Privacy Policy' },
  { href: '/terms-and-conditions', label: 'Terms' },
  { href: '/contact', label: 'Contact' },
];
---

<footer style="
  border-top: 1px solid #1a1a1a;
  padding: 48px 24px;
  background: #000;
">
  <div style="
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  ">
    <div style="display: flex; gap: 28px; flex-wrap: wrap; justify-content: center;">
      {footerLinks.map(link => (
        <a
          href={link.href}
          class="footer-link"
          style="font-size: 14px; color: #888; transition: color 0.15s; letter-spacing: -0.2px;"
        >
          {link.label}
        </a>
      ))}
    </div>
    <p style="font-size: 12px; color: #444; text-align: center; line-height: 1.5;">
      © {new Date().getFullYear()} Real Caffeine Calculator &mdash; realcaffeinecalculator.com<br />
      For informational purposes only. Not medical advice.
    </p>
  </div>
</footer>
