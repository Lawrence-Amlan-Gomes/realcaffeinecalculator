---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Terms and Conditions — Real Caffeine Calculator"
  description="Terms and conditions for using Real Caffeine Calculator. This tool is for informational purposes only."
  canonical="https://realcaffeinecalculator.com/terms-and-conditions"
>

<section style="padding: 72px 24px 96px;">
  <div style="max-width: 640px; margin: 0 auto;">

    <p style="font-size: 12px; font-weight: 500; color: #555; letter-spacing: 0.6px; text-transform: uppercase; font-family: 'Courier New', monospace; margin-bottom: 20px;">
      Legal
    </p>

    <h1 style="font-size: 36px; font-weight: 600; letter-spacing: -1.4px; color: #fff; line-height: 1.1; margin-bottom: 8px;">
      Terms and Conditions
    </h1>
    <p style="font-size: 13px; color: #444; margin-bottom: 48px;">Last updated: June 14, 2026</p>

    <div style="display: flex; flex-direction: column; gap: 36px; color: #888; font-size: 15px; line-height: 1.75;">

      <div>
        <h2 style="font-size: 16px; font-weight: 600; color: #ededed; margin-bottom: 10px; letter-spacing: -0.3px;">
          Acceptance of terms
        </h2>
        <p>
          By accessing or using realcaffeinecalculator.com ("the Site"), you agree to be bound by these Terms and Conditions. If you do not agree, please do not use the Site.
