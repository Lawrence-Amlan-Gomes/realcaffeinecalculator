---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does the caffeine calculator work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It uses caffeine's 5-hour half-life to calculate how much remains in your system over time. Enter your drink, size, and time consumed — the calculator shows your current caffeine level and projects when it drops below the 50mg sleep-safe threshold."
      }
    },
    {
      "@type": "Question",
      "name": "What is caffeine half-life?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Caffeine half-life is the time it takes your body to eliminate half the caffeine in your system. For most adults it's about 5 hours, meaning a 200mg coffee at noon leaves ~100mg at 5pm and ~50mg at 10pm."
      }
    },
    {
      "@type": "Question",
      "name": "How much caffeine is safe per day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The FDA considers 400mg per day safe for healthy adults. That's roughly 4 standard cups of home-brewed coffee. The calculator warns you if you exceed this limit."
      }
    },
    {
      "@type": "Question",
      "name": "When should I stop drinking coffee before bed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use your bedtime as the target. The calculator works backwards from your bedtime so caffeine drops below 50mg by then. For an 11pm bedtime, your last coffee should typically be before 3–4pm."
      }
    },
    {
      "@type": "Question",
      "name": "Does body weight affect caffeine metabolism?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Body weight has a minor effect on caffeine distribution but does not significantly change metabolism rate. The 5-hour half-life is the dominant factor for most adults."
      }
    }
  ]
};
---

<Layout
  title="Caffeine Calculator — Real Caffeine Calculator"
  description="See exactly how much caffeine is in your body right now. Our caffeine half life calculator shows when it's safe to sleep based on your drinks, timing, and bedtime."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

<!-- ─── Hero ─── -->
<section style="padding: 56px 24px 40px; text-align: center;">
  <div style="max-width: 680px; margin: 0 auto;">
    <h1 style="font-size: 42px; font-weight: 600; letter-spacing: -1.8px; color: #fff; line-height: 1.05; margin-bottom: 14px;">
      Caffeine Calculator
    </h1>
    <p style="font-size: 17px; color: #888; line-height: 1.65; max-width: 520px; margin: 0 auto;">
      Log your drinks. See exactly how much caffeine is in your system right now — and when it'll be safe to sleep.
    </p>
  </div>
</section>

<!-- ─── Calculator ─── -->
<section style="padding: 0 24px 64px;">
  <div style="max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: 12px;">

    <!-- Inputs card -->
    <div class="calc-card" style="padding: 24px;">
      <div style="font-size: 12px; font-weight: 500; color: #555; letter-spacing: 0.6px; text-transform: uppercase; font-family: 'Courier New', monospace; margin-bottom: 18px;">
        Your Drinks
      </div>

      <div id="drink-rows" style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px;"></div>

      <button
        id="add-drink"
        style="
          height: 36px;
          padding: 0 16px;
          background: transparent;
          border: 1px solid #1a1a1a;
          border-radius: 9999px;
          color: #888;
          font-size: 13px;
          font-weight: 500;
          transition: border-color 0.15s, color 0.15s;
          cursor: pointer;
        "
        onmouseover="this.style.borderColor='#2e2e2e';this.style.color='#ededed'"
        onmouseout="this.style.borderColor='#1a1a1a';this.style.color='#888'"
      >
        + Add another drink
      </button>

      <!-- Weight + Bedtime -->
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid #111;
      ">
        <div>
          <label style="display: block; font-size: 12px; color: #555; margin-bottom: 6px; font-weight: 500; letter-spacing: -0.1px;">
            Body weight (lbs) <span style="color:#333;">— shows mg/kg load</span>
          </label>
          <input
            type="number"
            id="weight"
            class="calc-input"
            placeholder="e.g. 160"
            min="50"
            max="500"
            style="width: 100%;"
          />
        </div>
        <div>
          <label style="display: block; font-size: 12px; color: #555; margin-bottom: 6px; font-weight: 500;">
            Bedtime
          </label>
          <input
            type="time"
            id="bedtime"
            class="calc-input"
            value="23:00"
            style="width: 100%;"
          />
        </div>
      </div>
    </div>

    <!-- Outputs card -->
    <div class="calc-card">

      <!-- Big number -->
      <div style="text-align: center; padding: 36px 24px 24px;">
        <div style="font-size: 76px; font-weight: 600; letter-spacing: -4px; color: #fff; line-height: 1;">
          <span id="current-mg">0</span><span style="font-size: 30px; font-weight: 400; color: #555; margin-left: 4px; letter-spacing: -1px;">mg</span>
        </div>
        <div style="font-size: 13px; color: #555; margin-top: 6px; letter-spacing: -0.1px;">
          caffeine in your system right now
        </div>
        <div style="margin-top: 16px;">
          <span id="status-badge" class="status-badge neutral">Log a drink to start</span>
        </div>
      </div>

      <!-- Chart -->
      <div style="padding: 0 20px 4px;">
        <svg
          id="caffeine-chart"
          viewBox="0 0 600 200"
          width="100%"
          preserveAspectRatio="xMidYMid meet"
          style="display: block; overflow: visible;"
          aria-label="Caffeine decay chart"
        >
          <text x="300" y="92" text-anchor="middle" fill="#222" font-size="14" font-family="Inter, sans-serif" font-weight="500">Add a drink above</text>
          <text x="300" y="112" text-anchor="middle" fill="#1a1a1a" font-size="12" font-family="Inter, sans-serif">to see your caffeine decay chart</text>
        </svg>

        <!-- Chart legend — hidden until drinks are logged -->
        <div id="chart-legend" style="display:none; flex-wrap:wrap; gap:8px 20px; padding:10px 4px 0;">
          <span style="display:flex;align-items:center;gap:6px;">
            <svg width="20" height="8" style="flex-shrink:0"><line x1="0" y1="4" x2="20" y2="4" stroke="#0070f3" stroke-width="2.5" stroke-linecap="round"/></svg>
            <span style="font-size:11px;color:#555;white-space:nowrap;">Caffeine level</span>
          </span>
          <span style="display:flex;align-items:center;gap:6px;">
            <svg width="20" height="8" style="flex-shrink:0"><line x1="0" y1="4" x2="20" y2="4" stroke="#f5a623" stroke-width="1.5" stroke-dasharray="5,4"/></svg>
            <span style="font-size:11px;color:#555;white-space:nowrap;">Sleep threshold (50mg)</span>
          </span>
          <span style="display:flex;align-items:center;gap:6px;">
            <svg width="10" height="12" style="flex-shrink:0"><line x1="5" y1="0" x2="5" y2="12" stroke="rgba(255,255,255,0.45)" stroke-width="1.5" stroke-dasharray="3,2.5"/></svg>
            <span style="font-size:11px;color:#555;white-space:nowrap;">Now</span>
          </span>
          <span style="display:flex;align-items:center;gap:6px;">
            <svg width="10" height="12" style="flex-shrink:0"><line x1="5" y1="0" x2="5" y2="12" stroke="#8b5cf6" stroke-width="1.5" stroke-dasharray="4,3" opacity="0.85"/></svg>
            <span style="font-size:11px;color:#555;white-space:nowrap;">Bedtime</span>
          </span>
          <span style="display:flex;align-items:center;gap:6px;">
            <svg width="14" height="8" style="flex-shrink:0"><rect x="0" y="0" width="14" height="8" fill="#22c55e" fill-opacity="0.25" rx="1.5"/></svg>
            <span style="font-size:11px;color:#555;white-space:nowrap;">Safe (&lt;50mg)</span>
          </span>
          <span style="display:flex;align-items:center;gap:6px;">
            <svg width="14" height="8" style="flex-shrink:0"><rect x="0" y="0" width="14" height="8" fill="#f5a623" fill-opacity="0.25" rx="1.5"/></svg>
            <span style="font-size:11px;color:#555;white-space:nowrap;">Moderate (50–150mg)</span>
          </span>
          <span style="display:flex;align-items:center;gap:6px;">
            <svg width="14" height="8" style="flex-shrink:0"><rect x="0" y="0" width="14" height="8" fill="#ef4444" fill-opacity="0.22" rx="1.5"/></svg>
            <span style="font-size:11px;color:#555;white-space:nowrap;">High (&gt;150mg)</span>
          </span>
        </div>
      </div>

      <!-- Clears at / Latest safe -->
      <div style="
        margin: 4px 20px 0;
        padding: 16px 0;
        border-top: 1px solid #111;
        display: flex;
        flex-direction: column;
        gap: 12px;
      ">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <span class="stat-label" style="font-size: 13px; color: #555;">Caffeine clears at <span class="stat-sub" style="color:#333; font-size:11px;">(below 50mg)</span></span>
          <span id="clears-at" style="font-size: 14px; color: #ededed; font-weight: 500; font-variant-numeric: tabular-nums;">—</span>
        </div>
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <span class="stat-label" style="font-size: 13px; color: #555;">Latest safe coffee time <span class="stat-sub" style="color:#333; font-size:11px;">(standard cup)</span></span>
          <span id="latest-safe" style="font-size: 14px; color: #ededed; font-weight: 500; font-variant-numeric: tabular-nums;">—</span>
        </div>
        <div id="mgkg-row" style="display:none; justify-content:space-between; align-items:center;">
          <span style="font-size: 13px; color: #555;">Total caffeine load <span style="color:#333; font-size:11px;">(mg per kg bodyweight)</span></span>
          <span id="mgkg-val" style="font-size: 14px; font-weight: 500; font-variant-numeric: tabular-nums;">—</span>
        </div>
      </div>

      <!-- 400mg warning -->
      <div id="overdose-warning" class="warning-banner" style="margin: 8px 20px 20px; display: none;">
        <span style="flex-shrink:0;">⚠</span>
        <span>Total intake exceeds 400mg — the FDA's recommended daily maximum. Consider stopping for the day.</span>
      </div>

    </div>

  </div>
</section>

<!-- ─── SEO content ─── -->
<section style="
  border-top: 1px solid #111;
  padding: 72px 24px;
  background: #020202;
">
  <div style="max-width: 680px; margin: 0 auto;">

    <h2 style="font-size: 28px; font-weight: 600; letter-spacing: -1px; color: #fff; margin-bottom: 40px; line-height: 1.2;">
      Understanding Caffeine Half-Life
    </h2>

    <div style="display: flex; flex-direction: column; gap: 36px;">

      <div>
        <h3 style="font-size: 16px; font-weight: 600; color: #ededed; margin-bottom: 10px; letter-spacing: -0.3px;">
          What is caffeine half-life?
        </h3>
        <p style="font-size: 15px; color: #888; line-height: 1.75;">
          Caffeine half-life is the time it takes your body to eliminate half the caffeine in your bloodstream. For most healthy adults, this sits at roughly 5 hours — meaning if you drink a coffee with 200mg of caffeine at noon, you'll have 100mg left at 5&nbsp;PM, 50mg by 10&nbsp;PM, and 25mg by 3&nbsp;AM. This is precisely why that afternoon pick-me-up can have you staring at the ceiling at midnight. Our <strong style="color:#ededed; font-weight:500;">caffeine half life calculator</strong> uses this pharmacokinetic constant to plot your exact position on the decay curve in real time, so there's no more guessing.
        </p>
      </div>

      <div>
        <h3 style="font-size: 16px; font-weight: 600; color: #ededed; margin-bottom: 10px; letter-spacing: -0.3px;">
          How this caffeine calculator works
        </h3>
        <p style="font-size: 15px; color: #888; line-height: 1.75;">
          This <strong style="color:#ededed; font-weight:500;">caffeine calculator</strong> applies the standard exponential decay formula: <em>remaining_mg = dose_mg × (0.5 ^ (hours_elapsed / 5))</em>. When you log multiple drinks, each one gets its own independent decay curve, and the calculator sums them at any given moment to show your total. The chart spans from your first drink to 24 hours later. The orange dashed line marks the 50mg sleep-safe threshold — the level at which most people can fall asleep without meaningful caffeine interference. The "Caffeine clears at" field tells you the exact time you'll cross below 50mg, and "Latest safe coffee time" works backwards from your bedtime to find the last moment you could have a standard 95mg cup without disrupting sleep.
        </p>
      </div>

      <div>
        <h3 style="font-size: 16px; font-weight: 600; color: #ededed; margin-bottom: 10px; letter-spacing: -0.3px;">
          Why timing matters for sleep
        </h3>
        <p style="font-size: 15px; color: #888; line-height: 1.75;">
          Sleep quality degrades from caffeine well before you "feel" wired. Research published in the Journal of Clinical Sleep Medicine found that caffeine consumed 6 hours before bed reduces total sleep time by over an hour — even when subjects reported falling asleep without difficulty. Caffeine blocks adenosine receptors, the brain's primary sleep-pressure signal, creating a false sense of alertness that suppresses deep, restorative sleep stages. At 50mg remaining, the blocking effect is minimal for most adults, which is why this calculator uses that as the sleep-safe threshold. If you're experiencing fragmented sleep, poor recovery, or early morning grogginess, your caffeine timing may be the culprit even if your last cup was hours ago. The bedtime field lets you set a personalized cutoff based on your actual schedule rather than a generic recommendation.
        </p>
      </div>

      <div>
        <h3 style="font-size: 16px; font-weight: 600; color: #ededed; margin-bottom: 10px; letter-spacing: -0.3px;">
          How much caffeine is safe per day?
        </h3>
        <p style="font-size: 15px; color: #888; line-height: 1.75;">
          The FDA recommends a maximum of 400mg of caffeine per day for healthy adults — roughly four standard cups of drip coffee. Above this, caffeine commonly causes increased heart rate, anxiety, headaches, and compounded sleep disruption. Individual tolerance varies significantly. A <strong style="color:#ededed; font-weight:500;">caffeine calculator by weight and age</strong> reveals important nuance: children and adolescents should avoid caffeine entirely; pregnant women are advised to stay under 200mg daily; and some adults carry genetic variants of the CYP1A2 enzyme that cause caffeine to metabolize two to four times more slowly than average, making 200mg feel like 400mg. This calculator flags your intake when it surpasses the FDA's 400mg ceiling so you can make an informed call before reaching for another cup.
        </p>
      </div>

      <div>
        <h3 style="font-size: 16px; font-weight: 600; color: #ededed; margin-bottom: 10px; letter-spacing: -0.3px;">
          How different drinks compare
        </h3>
        <p style="font-size: 15px; color: #888; line-height: 1.75;">
          Caffeine content varies enormously between drinks. A Starbucks Cold Brew packs 205mg — nearly three times a standard espresso shot at 75mg. Energy drinks raise the stakes further: Bang Energy delivers 300mg per can, while Monster contains 160mg and Red Bull sits at 80mg. Traditional beverages are more modest — home-brewed coffee averages 95mg per 8oz cup, black tea contains around 47mg, and green tea a lighter 28mg. Even "low caffeine" options accumulate: three cups of black tea totals 141mg, on par with a Starbucks Latte. Size compounds everything; large drip coffees at chain restaurants routinely hit 300–400mg on their own. Log your actual drinks and sizes in this <strong style="color:#ededed; font-weight:500;">caffeine calculator</strong> to see exactly where your day's intake lands versus the 400mg daily limit — no estimating required.
        </p>
      </div>

    </div>
  </div>
</section>

<!-- ─── FAQ ─── -->
