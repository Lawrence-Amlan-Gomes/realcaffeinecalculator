<script>
  const DRINKS = [
    { id: 'sbux-espresso',  name: 'Starbucks Espresso Shot', mg: 75,  fixed: true  },
    { id: 'sbux-latte',     name: 'Starbucks Latte',         mg: 150, fixed: false },
    { id: 'sbux-coldbrew',  name: 'Starbucks Cold Brew',     mg: 205, fixed: false },
    { id: 'dunkin-coffee',  name: 'Dunkin Medium Coffee',    mg: 210, fixed: false },
    { id: 'dunkin-espresso',name: 'Dunkin Espresso',         mg: 118, fixed: true  },
    { id: 'red-bull',       name: 'Red Bull',                mg: 80,  fixed: true  },
    { id: 'monster',        name: 'Monster',                 mg: 160, fixed: true  },
    { id: 'bang',           name: 'Bang Energy',             mg: 300, fixed: true  },
    { id: 'home-coffee',    name: 'Home Brewed Coffee',      mg: 95,  fixed: false },
    { id: 'black-tea',      name: 'Black Tea',               mg: 47,  fixed: false },
    { id: 'green-tea',      name: 'Green Tea',               mg: 28,  fixed: false },
    { id: 'diet-coke',      name: 'Diet Coke',               mg: 46,  fixed: true  },
    { id: 'custom',         name: 'Custom',                  mg: 0,   fixed: true, custom: true },
  ];

  const SIZE_MULT = { small: 0.75, medium: 1.0, large: 1.4 };

  let rowCounter = 0;

  function getNow() {
    const d = new Date();
    return `${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
  }

  function timeStrToMs(timeStr) {
    const [h, m] = timeStr.split(':').map(Number);
    const d = new Date();
    d.setHours(h, m, 0, 0);
    const ms = d.getTime();
    // If more than 1 hour in the future, assume yesterday
    if (ms > Date.now() + 60 * 60 * 1000) return ms - 86400000;
    return ms;
  }

  function getBedtimeMs() {
    const val = (document.getElementById('bedtime')).value || '23:00';
    const [h, m] = val.split(':').map(Number);
    const d = new Date();
    d.setHours(h, m, 0, 0);
    let ms = d.getTime();
    if (ms <= Date.now()) ms += 86400000;
    return ms;
  }

  function calcCaffeineAt(entries, targetMs) {
    return entries.reduce((sum, e) => {
      if (!e.baseMg || e.baseMg <= 0 || !e.drinkMs) return sum;
      const elapsedH = (targetMs - e.drinkMs) / 3600000;
      if (elapsedH < 0) return sum;
      return sum + e.baseMg * Math.pow(0.5, elapsedH / 5);
    }, 0);
  }

  function getEntries() {
    const rows = document.querySelectorAll('.drink-row');
    return Array.from(rows).map(row => {
      const drinkSelect = row.querySelector('.drink-select');
      const sizeSelect  = row.querySelector('.size-select');
      const timeInput   = row.querySelector('.time-input');
      const customInput = row.querySelector('.custom-mg');

      const drinkId = drinkSelect ? drinkSelect.value : '';
      const drink   = DRINKS.find(d => d.id === drinkId);
      if (!drink) return { baseMg: 0, drinkMs: null };

      let baseMg;
      if (drink.custom) {
        baseMg = parseFloat(customInput ? customInput.value : '0') || 0;
      } else if (drink.fixed) {
        baseMg = drink.mg;
      } else {
        const size = sizeSelect ? sizeSelect.value : 'medium';
        baseMg = drink.mg * (SIZE_MULT[size] || 1.0);
      }

      const timeStr = timeInput ? timeInput.value : '';
      const drinkMs = timeStr ? timeStrToMs(timeStr) : null;

      return { baseMg, drinkMs };
    });
  }

  function formatTime(ms) {
    const d = new Date(ms);
    return d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
  }

  function chartColors() {
    const light = document.documentElement.classList.contains('light');
    return {
      grid:       light ? '#e8e8e8' : '#111',
      axes:       light ? '#d0d0d0' : '#1e1e1e',
      tick:       light ? '#999'    : '#333',
      yLabel:     light ? '#bbb'    : '#2d2d2d',
      nowText:    light ? '#aaa'    : '#555',
      emptyMain:  light ? '#bbb'    : '#444',
      emptySub:   light ? '#d0d0d0' : '#333',
    };
  }

  function updateChart(entries) {
    const svg = document.getElementById('caffeine-chart');
    if (!svg) return;

    const legendEl = document.getElementById('chart-legend');
    const C = chartColors();

    if (entries.length === 0) {
      svg.innerHTML = `
        <text x="300" y="92" text-anchor="middle" fill="${C.emptyMain}" font-size="14" font-family="Inter, sans-serif" font-weight="500">Add a drink above</text>
        <text x="300" y="112" text-anchor="middle" fill="${C.emptySub}" font-size="12" font-family="Inter, sans-serif">to see your caffeine decay chart</text>
      `;
      if (legendEl) legendEl.style.display = 'none';
      return;
    }

    if (legendEl) legendEl.style.display = 'flex';

    const firstDrink = Math.min(...entries.map(e => e.drinkMs));
    const startMs = firstDrink;
    const endMs   = startMs + 24 * 3600000;
    const nowMs   = Date.now();
    const bedMs   = getBedtimeMs();

    // Sample 240 points for a smooth curve
    const STEPS = 240;
    let maxMg = 60;
    const pts = [];
    for (let i = 0; i <= STEPS; i++) {
      const t  = startMs + (i / STEPS) * (endMs - startMs);
      const mg = calcCaffeineAt(entries, t);
      pts.push({ t, mg });
      if (mg > maxMg) maxMg = mg;
    }
    maxMg = maxMg * 1.15;

    // Layout constants
    const VW = 600, VH = 200;
    const PL = 52, PR = 16, PT = 20, PB = 32;
    const W  = VW - PL - PR;
    const H  = VH - PT - PB;
    const chartTop    = PT;
    const chartBottom = PT + H;

    const xS = (t)  => PL + ((t - startMs) / (endMs - startMs)) * W;
    const yS = (mg) => PT + H - Math.min((mg / maxMg) * H, H);

    // Curve points
    const polyPts = pts.map(p => `${xS(p.t).toFixed(1)},${yS(p.mg).toFixed(1)}`).join(' ');
    const fillPts = `${PL},${chartBottom} ${polyPts} ${(PL + W).toFixed(1)},${chartBottom}`;

    // Zone threshold pixel positions (clamped to chart area)
    const y50_px  = Math.max(chartTop, Math.min(chartBottom, yS(50)));
    const y150_px = Math.max(chartTop, Math.min(chartBottom, yS(150)));

    // 50mg threshold line y
    const y50line = yS(50).toFixed(1);

    // "Now" marker
    const nowInRange = nowMs >= startMs && nowMs <= endMs;
    const nowX  = nowInRange ? xS(nowMs) : null;
    const nowMg_val = nowInRange ? calcCaffeineAt(entries, nowMs) : 0;
    const nowY  = nowInRange ? yS(nowMg_val) : null;

    // Bedtime marker
    const bedInRange = bedMs >= startMs && bedMs <= endMs;
    const bedX = bedInRange ? xS(bedMs) : null;

    // X-axis time labels every 3 hours
    const xLabels = [];
    for (let h = 0; h <= 24; h += 4) {
      xLabels.push({ x: xS(startMs + h * 3600000), label: formatTime(startMs + h * 3600000) });
    }

    // Y-axis labels with smart step
    const yStep = maxMg > 400 ? 100 : maxMg > 200 ? 50 : maxMg > 100 ? 25 : 10;
    const yLabels = [];
    for (let mg = 0; mg <= maxMg; mg += yStep) {
      const y = yS(mg);
      if (y >= chartTop - 4) yLabels.push({ y, label: mg });
    }

    svg.innerHTML = `
      <defs>
        <linearGradient id="curveGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#0070f3" stop-opacity="0.3"/>
          <stop offset="100%" stop-color="#0070f3" stop-opacity="0.02"/>
        </linearGradient>
      </defs>

      <!-- Background zone bands: green=safe, amber=moderate, red=high -->
      <rect x="${PL}" y="${y50_px.toFixed(1)}" width="${W}" height="${(chartBottom - y50_px).toFixed(1)}" fill="#22c55e" fill-opacity="0.07"/>
      ${y50_px > chartTop + 1 ? `<rect x="${PL}" y="${y150_px.toFixed(1)}" width="${W}" height="${(y50_px - y150_px).toFixed(1)}" fill="#f5a623" fill-opacity="0.07"/>` : ''}
      ${y150_px > chartTop + 1 ? `<rect x="${PL}" y="${chartTop}" width="${W}" height="${(y150_px - chartTop).toFixed(1)}" fill="#ef4444" fill-opacity="0.07"/>` : ''}

      <!-- Horizontal grid lines + Y-axis tick labels -->
      ${yLabels.map(({ y, label }) => `
        <line x1="${PL}" y1="${y.toFixed(1)}" x2="${(PL+W).toFixed(1)}" y2="${y.toFixed(1)}" stroke="${C.grid}" stroke-width="1"/>
        <text x="${(PL-6).toFixed(1)}" y="${(y+3.5).toFixed(1)}" text-anchor="end" fill="${C.tick}" font-size="10" font-family="Inter,sans-serif">${label}</text>
      `).join('')}

      <!-- Y-axis label -->
      <text x="9" y="${(PT + H / 2 + 2).toFixed(1)}" text-anchor="middle" fill="${C.yLabel}" font-size="9" font-family="Inter,sans-serif" transform="rotate(-90,9,${(PT + H / 2 + 2).toFixed(1)})">mg caffeine</text>

      <!-- 50mg sleep-safe threshold line -->
      <line x1="${PL}" y1="${y50line}" x2="${(PL+W).toFixed(1)}" y2="${y50line}" stroke="#f5a623" stroke-width="1.5" stroke-dasharray="5,4"/>
      <text x="${(PL+5).toFixed(1)}" y="${(parseFloat(y50line)-4).toFixed(1)}" fill="#7a5c0a" font-size="9" font-family="Inter,sans-serif">sleep-safe 50mg</text>

      <!-- "Now" vertical marker -->
      ${nowX != null ? `
        <line x1="${nowX.toFixed(1)}" y1="${chartTop}" x2="${nowX.toFixed(1)}" y2="${chartBottom}" stroke="#ffffff" stroke-width="1" stroke-dasharray="3,3" opacity="0.35"/>
        <text x="${nowX.toFixed(1)}" y="${(chartTop - 5).toFixed(1)}" text-anchor="middle" fill="${C.nowText}" font-size="9" font-family="Inter,sans-serif">now</text>
      ` : ''}

      <!-- Bedtime vertical marker -->
      ${bedX != null ? `
        <line x1="${bedX.toFixed(1)}" y1="${chartTop}" x2="${bedX.toFixed(1)}" y2="${chartBottom}" stroke="#8b5cf6" stroke-width="1.5" stroke-dasharray="4,3" opacity="0.75"/>
        <text x="${bedX.toFixed(1)}" y="${(chartTop - 5).toFixed(1)}" text-anchor="middle" fill="#8b5cf6" font-size="9" font-family="Inter,sans-serif">bedtime</text>
      ` : ''}

      <!-- Gradient area fill under curve -->
      <polygon points="${fillPts}" fill="url(#curveGrad)"/>

      <!-- Caffeine decay curve -->
      <polyline points="${polyPts}" fill="none" stroke="#0070f3" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>

      <!-- "Now" dot on curve — bullseye marker -->
      ${nowX != null && nowY != null ? `
        <circle cx="${nowX.toFixed(1)}" cy="${nowY.toFixed(1)}" r="5" fill="#0070f3" stroke="#000" stroke-width="1.5"/>
        <circle cx="${nowX.toFixed(1)}" cy="${nowY.toFixed(1)}" r="2" fill="#fff"/>
      ` : ''}

      <!-- X-axis time labels -->
      ${xLabels.map(({ x, label }) => `
        <text x="${x.toFixed(1)}" y="${(chartBottom + 16).toFixed(1)}" text-anchor="middle" fill="${C.tick}" font-size="9" font-family="Inter,sans-serif">${label}</text>
      `).join('')}

      <!-- Chart axes -->
      <line x1="${PL}" y1="${chartTop}" x2="${PL}" y2="${chartBottom}" stroke="${C.axes}" stroke-width="1"/>
      <line x1="${PL}" y1="${chartBottom}" x2="${(PL+W).toFixed(1)}" y2="${chartBottom}" stroke="${C.axes}" stroke-width="1"/>
    `;
  }

  function calculate() {
    const entries     = getEntries();
    const nowMs       = Date.now();
    const validEntries = entries.filter(e => e.baseMg > 0 && e.drinkMs !== null);
    const hasData     = validEntries.length > 0;

    const currentMg   = calcCaffeineAt(validEntries, nowMs);
    const totalIntake = entries.reduce((s, e) => s + (e.baseMg || 0), 0);

    // Current mg display
    const mgEl = document.getElementById('current-mg');
    if (mgEl) mgEl.textContent = Math.round(currentMg).toString();

    // Status badge — neutral when no drinks logged
    const badge = document.getElementById('status-badge');
    if (badge) {
      if (!hasData) {
        badge.className  = 'status-badge neutral';
        badge.textContent = 'Log a drink to start';
      } else if (currentMg <= 50) {
        badge.className  = 'status-badge safe';
        badge.textContent = 'Safe to sleep';
      } else if (currentMg <= 150) {
        badge.className  = 'status-badge warn';
        badge.textContent = 'Cutting it close';
      } else {
        badge.className  = 'status-badge danger';
        badge.textContent = 'Too much for sleep';
      }
    }

    // Clears at — time caffeine drops below 50mg
    const clearsEl = document.getElementById('clears-at');
    if (clearsEl) {
      if (!hasData) {
        clearsEl.textContent = '—';
      } else if (currentMg < 50) {
        clearsEl.textContent = 'Already clear';
      } else {
        let clearMs = null;
        for (let min = 0; min <= 1440; min += 5) {
          const t  = nowMs + min * 60000;
          const mg = calcCaffeineAt(validEntries, t);
          if (mg < 50) { clearMs = t; break; }
        }
        clearsEl.textContent = clearMs ? formatTime(clearMs) : '> 24 hrs';
      }
    }

    // Latest safe coffee time — works back from bedtime
    const safeEl = document.getElementById('latest-safe');
    if (safeEl) {
      const isLight = document.documentElement.classList.contains('light');
      if (!hasData) {
        safeEl.textContent = '—';
        safeEl.style.color = isLight ? '#111' : '#ededed';
      } else {
        const bedMs = getBedtimeMs();
        const existingAtBed = calcCaffeineAt(validEntries, bedMs);
        const headroom = 50 - existingAtBed;

        if (headroom <= 0) {
          safeEl.textContent = 'None today';
          safeEl.style.color = '#ef4444';
        } else {
          const REF_MG = 95;
          const hoursNeeded = 5 * Math.log2(REF_MG / headroom);
          const latestMs = bedMs - hoursNeeded * 3600000;
          if (latestMs < nowMs - 3600000) {
            safeEl.textContent = 'Window passed';
            safeEl.style.color = isLight ? '#555' : '#888';
          } else {
            safeEl.textContent = formatTime(latestMs);
            safeEl.style.color = isLight ? '#111' : '#ededed';
          }
        }
      }
    }

    // 400mg daily limit warning
    const warnEl = document.getElementById('overdose-warning');
    if (warnEl) {
      warnEl.style.display = totalIntake > 400 ? 'flex' : 'none';
    }

    // mg/kg load — only when weight is provided
    const weightLbs = parseFloat((document.getElementById('weight')).value || '0') || 0;
    const mgkgRow = document.getElementById('mgkg-row');
    const mgkgVal = document.getElementById('mgkg-val');
    if (mgkgRow && mgkgVal) {
      if (weightLbs > 0 && totalIntake > 0) {
        const weightKg = weightLbs * 0.453592;
        const mgPerKg  = totalIntake / weightKg;
        mgkgRow.style.display = 'flex';
        mgkgVal.textContent   = mgPerKg.toFixed(1) + ' mg/kg';
        mgkgVal.style.color   = mgPerKg > 6 ? '#ef4444' : mgPerKg > 3 ? '#f5a623' : '#22c55e';
      } else {
        mgkgRow.style.display = 'none';
      }
    }

    // Chart
    updateChart(validEntries);
  }

  function updateRemoveButtons() {
    const rows = document.querySelectorAll('.drink-row');
    rows.forEach(row => {
      const btn = row.querySelector('.remove-btn');
      if (btn) {
        (btn).style.visibility = rows.length <= 1 ? 'hidden' : 'visible';
      }
    });
  }

  function createDrinkRow() {
    const id  = rowCounter++;
    const div = document.createElement('div');
    div.className = 'drink-row';
    div.dataset.rowId = String(id);
    div.style.cssText = 'display:flex;gap:8px;align-items:center;flex-wrap:wrap;';

    const IS = 'height:40px;background:#050505;border:1px solid #1a1a1a;border-radius:6px;color:#ededed;padding:0 12px;font-size:14px;outline:none;';

    // Drink select
    const drinkSel = document.createElement('select');
    drinkSel.className = 'drink-select calc-input';
    drinkSel.style.cssText = IS + 'flex:1;min-width:180px;cursor:pointer;';
    DRINKS.forEach(d => {
      const opt = document.createElement('option');
      opt.value = d.id;
      opt.textContent = d.custom ? 'Custom (enter mg)' : `${d.name} — ${d.mg}mg`;
      drinkSel.appendChild(opt);
    });

    // Size select
    const sizeSel = document.createElement('select');
    sizeSel.className = 'size-select calc-input';
    sizeSel.style.cssText = IS + 'width:106px;cursor:pointer;';
    [['small','Small'],['medium','Regular'],['large','Large']].forEach(([v,l]) => {
      const opt = document.createElement('option');
      opt.value = v; opt.textContent = l;
      if (v === 'medium') opt.selected = true;
      sizeSel.appendChild(opt);
    });

    // Time input
    const timeIn = document.createElement('input');
    timeIn.type = 'time';
    timeIn.className = 'time-input calc-input';
    timeIn.style.cssText = IS + 'width:122px;';
    timeIn.value = getNow();

    // Custom mg
    const customIn = document.createElement('input');
    customIn.type = 'number';
    customIn.className = 'custom-mg calc-input';
    customIn.placeholder = 'mg';
    customIn.min = '0'; customIn.max = '1000';
    customIn.style.cssText = IS + 'width:76px;display:none;';

    // Remove button
    const removeBtn = document.createElement('button');
    removeBtn.className = 'remove-btn';
    removeBtn.type = 'button';
    removeBtn.innerHTML = '&times;';
    removeBtn.style.cssText = `
      width:32px;height:32px;flex-shrink:0;
      border-radius:50%;border:1px solid #1a1a1a;
      background:transparent;color:#555;
      font-size:18px;line-height:1;
      display:flex;align-items:center;justify-content:center;
      transition:color 0.15s,border-color 0.15s;
      visibility:hidden;
    `;
    removeBtn.addEventListener('mouseover', () => { removeBtn.style.color='#ef4444'; removeBtn.style.borderColor='#3a0a0a'; });
    removeBtn.addEventListener('mouseout',  () => { removeBtn.style.color='#555'; removeBtn.style.borderColor='#1a1a1a'; });
    removeBtn.addEventListener('click', () => { div.remove(); updateRemoveButtons(); calculate(); });

    function syncVisibility() {
      const drink = DRINKS.find(d => d.id === drinkSel.value);
      if (!drink) return;
      sizeSel.style.display   = drink.fixed  ? 'none' : '';
      customIn.style.display  = drink.custom ? '' : 'none';
    }

    drinkSel.addEventListener('change', () => { syncVisibility(); calculate(); });
    sizeSel.addEventListener('change', calculate);
    timeIn.addEventListener('change', calculate);
    customIn.addEventListener('input', calculate);

    div.appendChild(drinkSel);
    div.appendChild(sizeSel);
    div.appendChild(timeIn);
    div.appendChild(customIn);
    div.appendChild(removeBtn);

    syncVisibility();
    return div;
  }

  // ─── Init ───
  const drinkRowsEl = document.getElementById('drink-rows');
  if (drinkRowsEl) {
    drinkRowsEl.appendChild(createDrinkRow());
  }

  document.getElementById('add-drink')?.addEventListener('click', () => {
    if (drinkRowsEl) {
      drinkRowsEl.appendChild(createDrinkRow());
      updateRemoveButtons();
      calculate();
    }
  });

  document.getElementById('bedtime')?.addEventListener('change', calculate);
  document.getElementById('weight')?.addEventListener('input', calculate);

  // Initial calculation
  calculate();

  // Refresh every 60 seconds (live "now" update)
  setInterval(calculate, 60000);

  // Re-render chart with correct colours when theme toggles
  document.addEventListener('theme-change', calculate);
</script>
